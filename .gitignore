*.avi
*.mkv
*.mov
*.wmv
*.flv
*.webm
*.m4v
*.mpg
*.mpeg
*.3gp
*.ogv
*.rm
*.rmvb
*.asf
*.vob
*.ts
*.m2ts
*.mts
*.divx
*.xvid
*.f4v
*.m2v
*.mxf
*.qt

# Formatos de video de alta calidad
*.hevc
*.h264
*.h265
*.av1
*.vp9
*.vp8
*.prores

# Formatos de video específicos
*.dv
*.mpeg4
*.mp2v
*.3g2
*.amv
*.m1v
*.m2p
*.m4p
*.mjpeg
*.mjpg

# ============ ARCHIVOS DE AUDIO ============
*.mp3
*.wav
*.flac
*.aac
*.ogg
*.wma
*.m4a
*.opus
*.ac3
*.dts
*.ra
*.au
*.aiff
*.ape
*.mka

# ============ ARCHIVOS DE IMAGEN ============
